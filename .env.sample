# Required, set your OpenAI API key.
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_BASE_URL=https://YOUR_OPENAI_COMPATIBLE_GATEWAY/v1
OPENAI_MODEL=YOUR_MODEL_NAME
OPENAI_API_MODE=chat_completions

# Qwen Cloud hackathon deployment. When any QWEN_* variable is set, these
# values take precedence over OPENAI_* and both key and base URL are required.
# QWEN_API_KEY=YOUR_QWEN_CLOUD_API_KEY
# QWEN_BASE_URL=https://YOUR_QWEN_OPENAI_COMPATIBLE_ENDPOINT/v1
# QWEN_MODEL=qwen-plus

# Optional DataHub MCP integration. Mutation tools remain disabled by code.
# DATAHUB_GMS_URL=http://localhost:8080
# DATAHUB_GMS_TOKEN=YOUR_DATAHUB_PERSONAL_ACCESS_TOKEN
# DATAHUB_MCP_COMMAND=uvx
# DATAHUB_MCP_PACKAGE=mcp-server-datahub@latest

# Optional scanner settings.
# DEVPOST_MAX_PAGES=8

# Optional, uncomment and set when running without the Slack CLI (npm start).
# SLACK_APP_TOKEN=YOUR_SLACK_APP_TOKEN
# SLACK_BOT_TOKEN=YOUR_SLACK_BOT_TOKEN

# Optional, uncomment and set for OAuth mode (node app-oauth.js).
# SLACK_CLIENT_ID=YOUR_SLACK_CLIENT_ID
# SLACK_CLIENT_SECRET=YOUR_SLACK_CLIENT_SECRET
# SLACK_SIGNING_SECRET=YOUR_SLACK_SIGNING_SECRET
# SLACK_REDIRECT_URI=https://YOUR_NGROK_SUBDOMAIN.ngrok-free.app/slack/oauth_redirect

# Optional, uncomment and set when using a custom Slack instance.
# SLACK_API_URL=YOUR_SLACK_API_URL
