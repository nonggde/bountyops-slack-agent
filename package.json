{
  "name": "slack-bountyops-agent",
  "version": "0.1.0",
  "type": "module",
  "license": "Apache-2.0",
  "scripts": {
    "check": "npx tsc --checkJs --noEmit --skipLibCheck --esModuleInterop --target esnext --module nodenext --moduleResolution nodenext app.js",
    "demo:datahub": "node scripts/run-datahub-assessment.mjs",
    "start": "node app.js",
    "lint": "npx @biomejs/biome check .",
    "lint:fix": "npx @biomejs/biome check --write .",
    "test": "node --test",
    "verify:submission": "node scripts/verify-submission-readiness.mjs",
    "verify:qwen": "node scripts/verify-qwen-cloud.mjs"
  },
  "dependencies": {
    "@openai/agents": "^0.12.0",
    "@slack/bolt": "^4.7.3",
    "dotenv": "~17.4.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@slack/cli-hooks": "^1.3.3",
    "typescript": "^6.0.3"
  }
}
